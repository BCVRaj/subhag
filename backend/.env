# Backend Configuration
SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data Storage Paths (relative to backend/app/)
DATA_DIR=data
UPLOADS_DIR=data/uploads
JOBS_DIR=data/jobs
RESULTS_DIR=data/results

# OpenOA Configuration
OPENOA_ENABLE_REAL_ANALYSIS=true

# ============================================
# GOOGLE OAUTH CONFIGURATION (REQUIRED FOR GOOGLE SIGN-IN)
# ============================================
# To enable Google Sign-In:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:5173 to Authorized JavaScript origins
# 4. Copy your Client ID and paste it below
# 5. See GOOGLE_OAUTH_SETUP.md for detailed step-by-step guide
#
# Format: XXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
#
GOOGLE_CLIENT_ID=926382572179-t9oe2nv0u5hplmif9p5suq9spuq2iqes.apps.googleusercontent.com
